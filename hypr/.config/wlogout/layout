{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprshutdown",
    "text" : "Logout"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown -p `systemctl poweroff`",
    "text" : "Shutdown"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown -p `systemctl reboot`",
    "text" : "Reboot"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend"
}
